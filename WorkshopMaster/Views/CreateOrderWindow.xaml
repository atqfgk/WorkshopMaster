    <Grid Margin="8">
        <Grid.RowDefinitions>
            <!-- Верхняя часть: фиксированные поля -->
            <RowDefinition Height="Auto"/>
            <!-- Клиент -->
            <RowDefinition Height="Auto"/>
            <!-- Описание -->
            <RowDefinition Height="Auto"/>
            <!-- Дата -->

            <!-- Средняя часть: этапы и материалы - делим место поровну -->
            <RowDefinition Height="*"/>
            <!-- Этапы -->
            <RowDefinition Height="*"/>
            <!-- Материалы -->

            <!-- Итого и кнопки -->
            <RowDefinition Height="Auto"/>
            <!-- Предварительная стоимость -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопки -->
        </Grid.RowDefinitions>

        <!-- ===== ВЕРХНЯЯ ЧАСТЬ ===== -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,2,0,4">
            <TextBlock Text="Клиент:" Width="80" VerticalAlignment="Center"/>
            <ComboBox x:Name="cmbClient" Width="200"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,2,0,4">
            <TextBlock Text="Описание:" Width="80" VerticalAlignment="Center"/>
            <TextBox x:Name="txtDescription" Width="300"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,2,0,8">
            <TextBlock Text="Дата:" Width="80" VerticalAlignment="Center"/>
            <DatePicker x:Name="dpDueDate" SelectedDate="{x:Static sys:DateTime.Now}"/>
        </StackPanel>

        <!-- ===== ЭТАПЫ ===== -->
        <GroupBox Grid.Row="3" Header="Этапы" Margin="0,0,0,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <ComboBox x:Name="cmbStage" Width="110"/>
                    <ComboBox x:Name="cmbEmployee" Width="110"/>
                    <DatePicker x:Name="dpPlanStart" Width="100" SelectedDate="{x:Static sys:DateTime.Now}"/>
                    <DatePicker x:Name="dpPlanEnd" Width="100" SelectedDate="{x:Static sys:DateTime.Now}"/>
                    <TextBox x:Name="txtHours" Width="40" Text="0" HorizontalAlignment="Center"/>
                    <Button Content="+" Click="AddStage_Click" Width="25" Padding="0"/>
                </StackPanel>

                <!-- Компактная таблица -->
                <DataGrid x:Name="dgStages" Grid.Row="1" 
                          AutoGenerateColumns="False"
                          RowHeight="22" 
                          ColumnHeaderHeight="25"
                          VerticalScrollBarVisibility="Auto"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Этап" Binding="{Binding StageName}" Width="*"/>
                        <DataGridTextColumn Header="Сотр." Binding="{Binding EmployeeName}" Width="80"/>
                        <DataGridTextColumn Header="Начало" Binding="{Binding PlanStart, StringFormat=d}" Width="70"/>
                        <DataGridTextColumn Header="Конец" Binding="{Binding PlanEnd, StringFormat=d}" Width="70"/>
                        <DataGridTextColumn Header="Часы" Binding="{Binding Hours}" Width="45"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <!-- ===== МАТЕРИАЛЫ ===== -->
        <GroupBox Grid.Row="4" Header="Материалы" Margin="0,0,0,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <ComboBox x:Name="cmbMaterial" Width="140"/>
                    <TextBox x:Name="txtMaterialQty" Width="45" Text="0"/>
                    <Button Content="+" Click="AddMaterial_Click" Width="25" Padding="0"/>
                </StackPanel>

                <DataGrid x:Name="dgMaterials" Grid.Row="1"
                          AutoGenerateColumns="False"
                          RowHeight="22"
                          ColumnHeaderHeight="25"
                          VerticalScrollBarVisibility="Auto"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Материал" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="50"/>
                        <DataGridTextColumn Header="Ед." Binding="{Binding Unit}" Width="40"/>
                        <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=F2}" Width="60"/>
                        <DataGridTextColumn Header="Сумма" Binding="{Binding Sum, StringFormat=F2}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <!-- ===== ИТОГО ===== -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,4,0,8">
            <TextBlock Text="Предварительная стоимость:" Width="150"/>
            <TextBlock x:Name="lblPrelimCost" Text="0 ₽" FontWeight="Bold" FontSize="14"/>
        </StackPanel>

        <!-- ===== КНОПКИ (всегда внизу) ===== -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Bottom"
                    Margin="0,8,0,0">
            <Button Content="Сохранить" Click="SaveOrder_Click" 
                    MinWidth="90" Height="28" Margin="0,0,8,0"/>
            <Button Content="Отмена" Click="Cancel_Click" 
                    MinWidth="90" Height="28"/>
        </StackPanel>
    </Grid>
</Window>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- Таблица занимает всё доступное пространство -->
            <RowDefinition Height="*"/>
            <!-- Панель кнопок внизу -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Таблица отчётов (сверху) -->
        <DataGrid x:Name="dgReport" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#F5F5F5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер заказа" Binding="{Binding НомерЗаказа}" Width="120"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding Клиент}" Width="180"/>
                <DataGridTextColumn Header="Дата приёма" Binding="{Binding ДатаПриема, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Плановая дата" Binding="{Binding ДатаИсполненияПлан, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Факт. дата" Binding="{Binding ДатаИсполненияФакт, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Статус}" Width="100"/>
                <DataGridTextColumn Header="Отклонение" Binding="{Binding Отклонение}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
        
        <!-- Панель кнопок (внизу справа) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Обновить" Click="BtnRefresh_Click" Width="90" Margin="0,0,10,0"/>
            <Button Content="Закрыть" Click="BtnClose_Click" Width="90"/>
        </StackPanel>
    </Grid>
</Window>
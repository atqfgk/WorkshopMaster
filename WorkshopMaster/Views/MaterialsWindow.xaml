    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="dgMaterials" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#F5F5F5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Название}" Width="200"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Категория}" Width="130"/>
                <DataGridTextColumn Header="Ед. изм." Binding="{Binding ЕдиницаИзмерения}" Width="80"/>
                <DataGridTextColumn Header="Цена продажи" Binding="{Binding ЦенаПродажи, StringFormat={}{0:N2} ₽}" Width="120"/>
                <DataGridTextColumn Header="Текущий остаток" Binding="{Binding ТекущийОстаток}" Width="120"/>
                <DataGridTextColumn Header="Мин. остаток" Binding="{Binding МинОстаток}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnAdd" Content="Добавить" Width="90" Margin="5" Click="Add_Click" />
            <Button x:Name="btnEdit" Content="Изменить" Width="90" Margin="5" Click="Edit_Click" />
            <Button x:Name="btnDelete" Content="Удалить" Width="90" Margin="5" Click="Delete_Click" />
            <Button x:Name="btnReceipt" Content="Приход" Width="90" Margin="5" Click="Receipt_Click" />
            <Button Content="Закрыть" Width="90" Margin="5" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
<Window x:Class="WorkshopMaster.Views.OrderDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WorkshopMaster.Views"
        mc:Ignorable="d"
        Title="Детали заказа" Height="600" Width="800" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Номер заказа:" Width="100" FontWeight="Bold"/>
            <TextBlock x:Name="lblOrderNumber" Text="" Width="150"/>
            <TextBlock Text="Статус:" Width="60" FontWeight="Bold" Margin="20,0,0,0"/>
            <ComboBox x:Name="cmbStatus" Width="120" IsEnabled="False"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Клиент:" Width="100" FontWeight="Bold"/>
            <TextBlock x:Name="lblClient" Text="" Width="250"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Описание:" Width="100" FontWeight="Bold"/>
            <TextBox x:Name="txtDescription" Width="400" IsReadOnly="True"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Плановая дата:" Width="100" FontWeight="Bold"/>
            <DatePicker x:Name="dpPlanDate" IsEnabled="False"/>
        </StackPanel>

        <TabControl Grid.Row="4" Margin="0,10">
            <TabItem Header="Этапы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5">
                        <Button x:Name="btnAddStage" Content="Добавить этап" Click="AddStage_Click" Visibility="Collapsed"/>
                        <Button x:Name="btnDeleteStage" Content="Удалить этап" Click="DeleteStage_Click" Visibility="Collapsed"/>
                    </StackPanel>
                    <DataGrid x:Name="dgStages" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Этап" Binding="{Binding StageName}" Width="150"/>
                            <DataGridTextColumn Header="Сотрудник" Binding="{Binding EmployeeName}" Width="150"/>
                            <DataGridTextColumn Header="Начало (план)" Binding="{Binding PlanStart}" Width="100"/>
                            <DataGridTextColumn Header="Конец (план)" Binding="{Binding PlanEnd}" Width="100"/>
                            <DataGridTextColumn Header="Часы (план)" Binding="{Binding Hours}" Width="80"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="Факт часы" Binding="{Binding ActualHours}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Материалы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5">
                        <Button x:Name="btnAddMaterial" Content="Добавить материал" Click="AddMaterial_Click" Visibility="Collapsed"/>
                        <Button x:Name="btnDeleteMaterial" Content="Удалить материал" Click="DeleteMaterial_Click" Visibility="Collapsed"/>
                    </StackPanel>
                    <DataGrid x:Name="dgMaterials" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Материал" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                            <DataGridTextColumn Header="Ед." Binding="{Binding Unit}" Width="80"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="100"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding Sum}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnSave" Content="Сохранить" Click="Save_Click" Visibility="Collapsed"/>
            <Button Content="Закрыть" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
<Window x:Class="WorkshopMaster.Views.MyTasksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WorkshopMaster.Views"
        mc:Ignorable="d"
        Title="Мои задания" Height="450" Width="700" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="dgTasks" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Заказ" Binding="{Binding НомерЗаказа}" Width="100"/>
                <DataGridTextColumn Header="Этап" Binding="{Binding Этап}" Width="150"/>
                <DataGridTextColumn Header="План даты" Binding="{Binding ПланДаты}" Width="120"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Статус}" Width="100"/>
                <DataGridTemplateColumn Header="Действие" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Кнопка}" Click="BtnAction_Click" Tag="{Binding PlanStageId}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Обновить" Click="BtnRefresh_Click"/>
            <Button Content="Закрыть" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
<Window x:Class="WorkshopMaster.Views.MaterialReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WorkshopMaster.Views" xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Приход материалов" Height="500" Width="700" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Номер накладной:" Width="120" VerticalAlignment="Center"/>
            <TextBox x:Name="txtInvoiceNumber" Width="200"/>
            <TextBlock Text="Дата:" Width="50" VerticalAlignment="Center" Margin="20,0,5,0"/>
            <DatePicker x:Name="dpReceiptDate" SelectedDate="{x:Static sys:DateTime.Now}" Width="120"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,5">
            <TextBlock Text="Материал:" Width="80" VerticalAlignment="Center"/>
            <ComboBox x:Name="cmbMaterial" Width="200" DisplayMemberPath="Название" SelectedValuePath="ID"/>
            <TextBlock Text="Количество:" Width="80" VerticalAlignment="Center" Margin="20,0,5,0"/>
            <TextBox x:Name="txtQuantity" Width="80" Text="0"/>
            <TextBlock Text="Цена закупки:" Width="100" VerticalAlignment="Center" Margin="20,0,5,0"/>
            <TextBox x:Name="txtPrice" Width="80" Text="0"/>
            <Button Content="Добавить" Click="AddItem_Click" Width="80" Margin="10,0,0,0"/>
        </StackPanel>
        <DataGrid x:Name="dgItems" Grid.Row="2" AutoGenerateColumns="False" Height="150">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Материал" Binding="{Binding MaterialName}" Width="200"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="100"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="100"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding Sum}" Width="100"/>
                <DataGridTemplateColumn Header="Дата" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="X" Click="RemoveItem_Click" Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Сохранить приход" Click="SaveReceipt_Click" Width="120" Margin="5"/>
            <Button Content="Отмена" Click="Close_Click" Width="80" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
<Window x:Class="WorkshopMaster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WorkshopMaster"
        mc:Ignorable="d"
        Title="WorkshopMaster - Главное меню" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <!--<Grid Margin="20">
        <StackPanel>
            <TextBlock Text="WorkshopMaster" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <Button x:Name="btnClients" Content="Клиенты" Click="BtnClients_Click"/>
            <Button x:Name="btnOrders" Content="Заказы" Click="BtnOrders_Click" />
            <Button x:Name="btnMyTasks" Content="Мои задания" Click="BtnMyTasks_Click" />
            <Button x:Name="btnMaterials" Content="Материалы" Click="BtnMaterials_Click" />
            <Button x:Name="btnReports" Content="Отчёты" Click="BtnReports_Click" />
            <Button Content="Выйти" Click="BtnExit_Click" Margin="0,30,0,0"/>

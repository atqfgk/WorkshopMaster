    <Grid Margin="20,10,20,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="WorkshopMaster" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <Button x:Name="btnClients" Content="Клиенты" Width="160" Height="50" Margin="10" Click="BtnClients_Click"/>
            <Button x:Name="btnOrders" Content="Заказы" Width="160" Height="50" Margin="10" Click="BtnOrders_Click"/>
            <Button x:Name="btnMaterials" Content="Материалы" Width="160" Height="50" Margin="10" Click="BtnMaterials_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <Button x:Name="btnMyTasks" Content="Мои задания" Width="160" Height="50" Margin="10" Click="BtnMyTasks_Click"/>
            <Button x:Name="btnReports" Content="Отчёты" Width="160" Height="50" Margin="10" Click="BtnReports_Click"/>
        </StackPanel>

        <Grid Grid.Row="3"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <Button Content="Выйти" Width="160" Height="50" Margin="10" Click="BtnExit_Click"/>
        </StackPanel>
    </Grid>
</Window>